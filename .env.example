# --- API Keys ---
HUBSPOT_API_KEY=
APOLLO_API_KEY=

# --- Slack ---
# Either webhook (simpler) or bot token. Pick one.
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_KPI_CHANNEL=#sdr-ops
SLACK_PROSPECTS_CHANNEL=#sdr-ops

# --- SDR mapping ---
# JSON: { "name": { "hubspot_owner_id": "...", "apollo_user_id": "..." } }
# Get HubSpot owner ids: Settings > Users & Teams > each user > URL has ownerId
# Get Apollo user ids: /users/search or Settings > Team
SDR_USERS_JSON={"Walter":{"hubspot_owner_id":"","apollo_user_id":""},"Nolan":{"hubspot_owner_id":"","apollo_user_id":""},"Quinn":{"hubspot_owner_id":"","apollo_user_id":""}}

# --- KPI tuning ---
# Comma-separated Apollo phone_call_outcome_id values that should count as "connected"
APOLLO_CONNECTED_OUTCOME_IDS=
# Comma-separated HubSpot hs_call_disposition IDs that should count as "connected"
HUBSPOT_CONNECTED_DISPOSITION_IDS=f240bbac-87c9-4f6e-bf70-924b57d47db7
DEDUP_POST_TO_SLACK=false

# --- Lookalike tuning ---
LOOKALIKE_EMPLOYEE_TOLERANCE=0.30
LOOKALIKE_REVENUE_TOLERANCE=0.40
LOOKALIKE_GEO_RADIUS_MILES=100

# --- Daily prospects tuning ---
PROSPECT_EXCLUDE_ENGAGED_DAYS=180

# --- Target titles for both lookalike + prospects ---
TARGET_TITLES=Proposals,Marketing,Pursuit,AI,Innovation,Business Development,Marketing Director,Proposal Manager
